{
  "name": "ocr-autofill-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare:assets": "node scripts/prepare-tesseract-assets.mjs",
    "patch:manifest": "node scripts/patch-dist-manifest.mjs",
    "build": "npm run prepare:assets && vite build && npm run patch:manifest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "tesseract.js": "^6.0.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.31",
    "@types/chrome": "^0.0.321",
    "@types/jsdom": "^21.1.7",
    "jsdom": "^24.1.3",
    "typescript": "^5.8.2",
    "vite": "^6.3.5",
    "vitest": "^2.1.9"
  }
}
